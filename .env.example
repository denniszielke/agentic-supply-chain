AZURE_RESOURCE_GROUP=
AZURE_LOCATION=
AZURE_IDENTITY_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_ID=
AZURE_CONTAINER_REGISTRY_ENDPOINT=
AZURE_REGISTRY=

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_SUPPLIER_INDEX_NAME=retail-suppliers
AZURE_SEARCH_CATEGORY_INDEX_NAME=retail-categories
AZURE_SEARCH_ITEM_INDEX_NAME=retail-items
AZURE_SEARCH_KNOWLEDGE_BASE_NAME=supply-chain-kb
AZURE_SEARCH_ADMIN_KEY=

AZURE_OPENAI_ENDPOINT=
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_PROJECT_ID=
AZURE_AI_PROJECT_NAME=
AZURE_AI_HOSTED_AGENT_NAME=shopping-agent
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small
OPENAI_API_VERSION=2024-05-01-preview

APPLICATIONINSIGHTS_CONNECTION_STRING=

# Set to true on re-runs when connections already exist to avoid update conflicts
SKIP_CONNECTION_CREATION=false
# Set to true on re-runs when role assignments already exist to avoid update conflicts
SKIP_ROLE_ASSIGNMENTS=false

SHOPPING_CHAT_CONTAINER_APP_NAME=shopping-chat
SHOPPING_AGENT_CONTAINER_APP_NAME=shopping-agent
PROMOTION_INGESTION_CONTAINER_APP_NAME=promotion-ingestion

# Simulated SAP Joule agent (external A2A server on ACA, registered in the control plane)
JOULE_AGENT_APP_NAME=joule-agent
JOULE_AGENT_PORT=8092
JOULE_AGENT_EXTERNAL=true
# JOULE_PUBLIC_URL=            # advertised in the agent card; derived from the ACA FQDN when unset
JOULE_AGENT_NAME=joule-agent
# JOULE_A2A_CONNECTION_NAME=  # RemoteA2A project connection (recommended; carries endpoint target + auth)
# JOULE_AGENT_URL=            # public A2A base URL; only needed without a RemoteA2A connection
JOULE_AGENT_CARD_PATH=/.well-known/agent-card.json
# JOULE_BLUEPRINT_ID=         # managed agent identity blueprint (Entra Agent ID) — advanced/undocumented
# JOULE_CONNECTION_ID=        # explicit RemoteA2A connection id (alternative to the name)
JOULE_PREVIEW_FEATURES=AgentEndpoints=V1Preview   # opt-in preview header; try ExternalAgents=V1Preview

